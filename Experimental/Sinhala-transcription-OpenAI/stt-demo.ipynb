    "from openai import OpenAI \n",
    "import os\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv()\n",
    "client = OpenAI()\n",
    "audio_file = open(\"test3.wav\", \"rb\")\n",
    "\n",
    "transcription = client.audio.transcription.create(\n",
    "    model=\"gpt-4o-transcribe\",\n",
    "    file=audio_file,\n",
    ")\n",
    "\n",
    "print(transcription.text)"
   ]
